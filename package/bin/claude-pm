#!/usr/bin/env bash
# Claude Project Manager - Main CLI Entry Point
# Usage: claude-pm [command] [options]

set -euo pipefail

# Resolve install location
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

# Source core library
source "${LIB_DIR}/core.sh"

CPM_VERSION="2.0.0"

show_help() {
  cat << HELP
Claude Project Manager v${CPM_VERSION}

Usage: claude-pm [command] [options]

Commands:
  select [mode]       Interactive TUI project selector (default)
  list [mode]         List projects (modes: quick, favorite, all)
  create              Create a new project (interactive)
  edit <folder>       Edit project metadata
  info <folder>       Show detailed project info
  preview <folder>    Preview project in compact format

  archive <folder>    Archive a project
  restore <folder>    Restore archived project
  delete <folder>     Permanently remove from registry

  cleanup prune       Prune old cache/logs (--days N)
  cleanup report      Show project size breakdown

  registry init       Initialize project registry
  registry add ...    Low-level registry operations
  registry help       Show registry subcommands

  setup               Interactive first-time setup
  version             Show version
  help                This help message

Environment:
  CLAUDE_PROJECTS_DIR   Projects directory (default: ~/.claude/projects)
  CLAUDE_ARCHIVE_DIR    Archive directory (default: ~/.claude/archive)

Examples:
  claude-pm                    Open project selector
  claude-pm list               List active projects
  claude-pm create             Create new project (interactive)
  claude-pm edit my-project    Edit project metadata
  claude-pm cleanup report     Show disk usage
HELP
}

show_version() {
  echo "Claude Project Manager v${CPM_VERSION}"
}

# Interactive first-time setup
run_setup() {
  source "${LIB_DIR}/registry.sh"

  echo -e "${CPM_CYAN}Claude Project Manager — Setup${CPM_NC}\n"

  local projects_dir
  local choice
  choice=$(prompt_choose "Where should projects be stored?" \
    "Default (~/.claude/projects)" \
    "Enter custom path" \
    "Use current directory")

  case "$choice" in
    "Default"*)
      projects_dir="$HOME/.claude/projects"
      ;;
    "Enter"*)
      projects_dir=$(prompt_input "Projects directory path")
      projects_dir="${projects_dir/#\~/$HOME}"
      ;;
    "Use current"*)
      projects_dir="$(pwd)"
      ;;
    *)
      projects_dir="$HOME/.claude/projects"
      ;;
  esac

  mkdir -p "$projects_dir"
  export CPM_HOME="$projects_dir"

  # Initialize registry
  registry_init

  echo ""
  print_success "Setup complete!"
  echo ""
  echo "Add to your shell profile (~/.zshrc or ~/.bashrc):"
  echo ""
  echo "  export CLAUDE_PROJECTS_DIR=\"$projects_dir\""
  echo "  eval \"\$(claude-pm shell-init)\""
  echo ""
}

# Output shell integration code
# Critical: The claude() function preserves working directory and validates dependencies
shell_init() {
  cat << 'SHELL'
# Claude Project Manager shell integration
# CRITICAL: This function wraps project navigation. Must preserve CWD on exit.
claude() {
  # Validate that the real claude command exists
  if ! command -v claude &>/dev/null; then
    echo "Error: 'claude' CLI not found on PATH. Install it before using claude-pm." >&2
    return 127
  fi

  # Help/version flags bypass project selection
  if [[ "$*" =~ (--help|--version|-h|-v) ]]; then
    command claude "$@"
    return $?
  fi

  local projects_dir="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"
  mkdir -p "$projects_dir" || {
    echo "Error: Failed to create projects directory: $projects_dir" >&2
    return 1
  }

  local current_dir
  current_dir=$(pwd)

  # If already in projects_dir, just run claude directly (avoid recursion)
  if [[ "$current_dir" == "$projects_dir/"* ]]; then
    command claude "$@"
    return $?
  fi

  # Use subshell to preserve original working directory
  (
    local selected
    selected=$(claude-pm select) || return 1
    [[ -z "$selected" ]] && return 1

    # Handle special selections
    if [[ "$selected" == "__QUICK_SESSION__" ]]; then
      command claude "$@"
      return $?
    fi

    if [[ "$selected" == "__NEW_PROJECT__" ]]; then
      local folder_name
      folder_name=$(claude-pm create) || return 1
      [[ -z "$folder_name" ]] && return 1
      cd "$projects_dir/$folder_name" || return 1
      command claude "$@"
      return $?
    fi

    # Change to selected project
    cd "$projects_dir/$selected" || {
      echo "Error: Failed to enter project: $projects_dir/$selected" >&2
      return 1
    }

    # Index with tldr if available and not indexed
    if command -v tldr &>/dev/null && [[ ! -d ".tldr" ]]; then
      echo "Indexing project..."
      tldr warm . 2>/dev/null || true
    fi

    # Offer doc review (with proper error handling)
    local docs=()
    for f in PROJECT.md PROJECT.json PLAN.md README.md; do
      [[ -f "$f" ]] && docs+=("$f")
    done

    if [[ ${#docs[@]} -gt 0 ]]; then
      local review
      if command -v gum &>/dev/null; then
        review=$(printf "Yes\nNo\n" | gum choose --header "Review docs? (${docs[*]})")
      else
        read -r -p "Review docs (${docs[*]})? [y/N]: " review
      fi

      if [[ "$review" == "Yes" || "$review" =~ ^[Yy] ]] && [[ ${#docs[@]} -gt 0 ]]; then
        # Use proper pager with error handling
        set +o pipefail  # Ignore SIGPIPE from pager
        "${PAGER:-less}" "${docs[@]}"
        set -o pipefail
      fi
    fi

    # Update registry (non-fatal if fails)
    claude-pm registry touch "$(basename "$(pwd)")" 2>/dev/null || true

    # Run the actual claude command
    command claude "$@"
  )

  # Return the subshell's exit code
  # NOTE: Working directory is automatically restored here
}

alias cpm="claude-pm"
SHELL
}

# Main command routing
main() {
  local command="${1:-select}"

  case "$command" in
    select)
      source "${LIB_DIR}/registry.sh"
      source "${LIB_DIR}/selector.sh"
      selector_main "${@:2}"
      ;;
    list)
      source "${LIB_DIR}/list.sh"
      list_main "${@:2}"
      ;;
    create)
      source "${LIB_DIR}/create.sh"
      create_main "${@:2}"
      ;;
    edit)
      source "${LIB_DIR}/edit.sh"
      edit_main "${@:2}"
      ;;
    preview)
      source "${LIB_DIR}/preview.sh"
      preview_main "${@:2}"
      ;;
    info)
      source "${LIB_DIR}/info.sh"
      info_main "${@:2}"
      ;;
    archive)
      source "${LIB_DIR}/delete.sh"
      archive_project "${@:2}"
      ;;
    restore)
      source "${LIB_DIR}/delete.sh"
      restore_project "${@:2}"
      ;;
    delete)
      source "${LIB_DIR}/delete.sh"
      delete_main "remove" "${@:2}"
      ;;
    cleanup)
      source "${LIB_DIR}/cleanup.sh"
      cleanup_main "${@:2}"
      ;;
    registry)
      source "${LIB_DIR}/registry.sh"
      registry_main "${@:2}"
      ;;
    setup)
      run_setup
      ;;
    shell-init)
      shell_init
      ;;
    version|--version|-v)
      show_version
      ;;
    help|--help|-h)
      show_help
      ;;
    *)
      echo "Error: Unknown command '$command'" >&2
      echo "Run 'claude-pm help' for usage" >&2
      return 1
      ;;
  esac
}

main "$@"
