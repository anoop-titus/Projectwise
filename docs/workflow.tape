# Projectwise Workflow Demo — Full claude() experience
# All project names and data are fictional

Set Shell "bash"
Set Theme "Dracula"
Set FontSize 15
Set Width 1400
Set Height 750
Set Padding 16
Set PlaybackSpeed 1

Output docs/workflow.gif

# Hide the setup command — type instantly then let script take over
Set TypingSpeed 0ms
Type "unset -f claude 2>/dev/null; clear; /tmp/cpm-demo-bin/run-demo"
Enter

# Script handles all timing internally (~28 seconds)
Sleep 32s
